# ============================================================
# Environment template — copy this file to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored and must never be committed.
# ============================================================

# Which LLM backend to use.
#   mock   → offline deterministic fake (no API key required)
#   qwen   → Alibaba DashScope (OpenAI-compatible), cheapest production option
#   openai → Official OpenAI API
LLM_PROVIDER=mock

# ── Qwen / DashScope ───────────────────────────────────────
# Sign up at https://dashscope-intl.console.aliyun.com/
# Generate an API key under: API Key Management
DASHSCOPE_API_KEY=

# ── OpenAI ─────────────────────────────────────────────────
# Sign up at https://platform.openai.com/
# Generate a key under: Settings → API Keys
OPENAI_API_KEY=

# ── HuggingFace ─────
# https://huggingface.co/settings/tokens  (Read permission is enough)
HF_TOKEN=
